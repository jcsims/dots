#!/usr/bin/env python3
"""Extract Atlassian Document Format (ADF) JSON from a Jira issue and convert to markdown.

Reads raw `jira issue view --raw` JSON from stdin.
Extracts the specified field (default: customfield_10080 / acceptance criteria).

Usage:
    jira issue view ISSUE-1 --raw | jira-adf-extract
    jira issue view ISSUE-1 --raw | jira-adf-extract --field description
"""

import argparse
import json
import sys


def inline_text(node):
    if "text" in node:
        txt = node["text"]
        for m in node.get("marks", []):
            mt = m.get("type", "")
            if mt == "strong":
                txt = f"**{txt}**"
            elif mt == "em":
                txt = f"*{txt}*"
            elif mt == "code":
                txt = f"`{txt}`"
            elif mt == "link":
                href = m.get("attrs", {}).get("href", "")
                txt = f"[{txt}]({href})"
        return txt

    parts = []
    for c in node.get("content", []):
        ntype = c.get("type", "")
        if ntype == "mention":
            attrs = c.get("attrs", {})
            parts.append("@" + (attrs.get("text") or attrs.get("id", "")))
        elif ntype == "hardBreak":
            parts.append("\n")
        elif ntype == "inlineCard":
            url = c.get("attrs", {}).get("url", "")
            parts.append(f"[{url}]({url})")
        else:
            parts.append(inline_text(c))
    return "".join(parts)


def adf_to_md(node, indent=0):
    if node is None:
        return ""

    t = node.get("type", "")
    out = []

    if t == "doc":
        for c in node.get("content", []):
            out.append(adf_to_md(c, indent))

    elif t == "paragraph":
        out.append(inline_text(node) + "\n")

    elif t == "bulletList":
        for c in node.get("content", []):
            out.append(adf_to_md(c, indent))

    elif t == "orderedList":
        for c in node.get("content", []):
            out.append(adf_to_md(c, indent))

    elif t == "listItem":
        prefix = "- "
        children = node.get("content", [])
        for c in children:
            if c.get("type") == "paragraph":
                out.append("  " * indent + prefix + inline_text(c))
                prefix = "  "
            else:
                out.append(adf_to_md(c, indent + 1))
        out.append("")

    elif t == "heading":
        level = node.get("attrs", {}).get("level", 1)
        out.append("#" * level + " " + inline_text(node) + "\n")

    elif t == "codeBlock":
        lang = node.get("attrs", {}).get("language", "")
        out.append(f"```{lang}")
        out.append(inline_text(node))
        out.append("```\n")

    elif t == "blockquote":
        for c in node.get("content", []):
            for line in adf_to_md(c, indent).splitlines():
                out.append("> " + line)
        out.append("")

    elif t == "table":
        rows = node.get("content", [])
        for ri, row in enumerate(rows):
            cells = row.get("content", [])
            cols = [inline_text(c).strip() for c in cells]
            out.append("| " + " | ".join(cols) + " |")
            if ri == 0:
                out.append("| " + " | ".join(["---"] * len(cols)) + " |")
        out.append("")

    else:
        for c in node.get("content", []):
            out.append(adf_to_md(c, indent))

    return "\n".join(out)


def main():
    parser = argparse.ArgumentParser(description="Extract ADF field from Jira JSON and convert to markdown")
    parser.add_argument(
        "--field",
        default="customfield_10080",
        help="JSON field to extract (default: customfield_10080 / acceptance criteria)",
    )
    args = parser.parse_args()

    data = json.load(sys.stdin)
    adf = data.get("fields", {}).get(args.field)

    if not adf:
        print("(none)")
        return

    print(adf_to_md(adf).strip())


if __name__ == "__main__":
    main()
