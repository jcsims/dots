#!/usr/bin/env bash
# Extract parent epic/story info from raw Jira JSON.
# Usage: jira issue view ISSUE-1 --raw | jira-parent
output=$(jq -r '
  .fields.parent // empty |
  "\(.fields.issuetype.name): \(.key) — \(.fields.summary) [\(.fields.status.name)]"
')

if [ -n "$output" ]; then
    echo "$output"
else
    echo "(none)"
fi
